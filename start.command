#!/bin/bash
# ═══════════════════════════════════════════════════════
#  Режиссёр-Аналитик — Автозапуск (двойной клик)
# ═══════════════════════════════════════════════════════

cd "$(dirname "$0")"

# Создаём виртуальное окружение если его нет
if [ ! -d "venv" ]; then
    echo "⏳ Первый запуск: создаю окружение..."
    python3 -m venv venv
fi

# Активируем
source venv/bin/activate

# Ставим зависимости если надо
pip install -q -r requirements.txt 2>/dev/null

# Запускаем
echo ""
echo "🎬 Запускаю Режиссёр-Аналитик..."
echo "   Браузер откроется автоматически."
echo "   Чтобы остановить — закрой это окно."
echo ""
python3 -m streamlit run dashboard.py --server.headless=false
